{
  "name": "pdf-image-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" \"eslint.config.ts\" --max-warnings=0",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"index.html\" \"package.json\" \"eslint.config.ts\" \"tsconfig.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"index.html\" \"package.json\" \"eslint.config.ts\" \"tsconfig.json\"",
    "knip": "knip",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.0",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624"
  }
}
